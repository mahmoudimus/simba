{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "simba hook SessionStart",
            "timeout": 15
          }
        ],
        "matcher": "startup|resume|clear"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "simba hook UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "simba hook PreToolUse",
            "timeout": 5
          }
        ],
        "matcher": "Bash|apply_patch|Edit|Write"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "simba hook PostToolUse",
            "timeout": 5
          }
        ],
        "matcher": "Bash|apply_patch|Edit|Write"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "simba hook Stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "simba hook SubagentStop",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "simba hook PermissionRequest",
            "timeout": 3
          }
        ],
        "matcher": "Bash|apply_patch|Edit|Write"
      }
    ]
  }
}
